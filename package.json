{
  "name": "ndsc-nextjs",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "node scripts/run-dev-local.js",
    "db:up": "docker compose -f docker-compose.local.yml up -d",
    "db:down": "docker compose -f docker-compose.local.yml down -v",
    "db:init": "node scripts/init-local-db.js",
    "db:seed": "node scripts/seed-local-db.js",
    "db:reset": "docker compose -f docker-compose.local.yml down -v && docker compose -f docker-compose.local.yml up -d && node scripts/init-local-db.js && node scripts/seed-local-db.js",
    "dev:jwt": "node scripts/dev-jwt.js",
    "build": "next build",
    "vercel-build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@supabase/supabase-js": "^2.107.0",
    "@xyflow/react": "^12.11.2",
    "katex": "^0.16.11",
    "lucide-react": "^0.500.0",
    "next": "^16.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0"
  }
}
